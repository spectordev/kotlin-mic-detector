# Server
PORT=3000
NODE_ENV=development

# MySQL — create user/DB with: mysql -u root -p < sql/bootstrap-mysql.sql
# Password must match bootstrap (default bgapp_secret). "using password: NO" means
# MYSQL_PASSWORD missing or .env not loaded — run `npm run check-env` from backend/.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=bgapp

# Uploads (Phase 2+)
UPLOAD_DIR=./data/uploads
MAX_FILE_BYTES=12582912

# SMTP (Phase 3) — use a real relay in production
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="test.from@mail.com"
SMTP_TEST_TO="test.to@mail.com"

# Phase 4
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_MS=5000
CLEANUP_RECORDING_AGE_HOURS=168
CLEANUP_INTERVAL_MS=3600000

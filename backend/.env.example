# Server
PORT=3000
NODE_ENV=development

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=bgapp
MYSQL_PASSWORD=bgapp_secret
MYSQL_DATABASE=bgapp

# Uploads (Phase 2+)
UPLOAD_DIR=./data/uploads
MAX_FILE_BYTES=12582912

# SMTP (Phase 3) — use a real relay in production
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BgApp Recorder <noreply@example.com>"

# Phase 4
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_BASE_MS=5000
CLEANUP_RECORDING_AGE_HOURS=168
CLEANUP_INTERVAL_MS=3600000
